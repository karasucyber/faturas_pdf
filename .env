# Define o modelo do Ollama que você baixou (ex: llama3, mistral, qwen2)
MODEL=ollama/llama3

# Desativa o envio de telemetria
OTEL_SDK_DISABLED=true

# Se o seu Ollama estiver rodando na porta padrão, o CrewAI já o encontrará.
# Caso precise especificar a URL, use:
# OPENAI_API_BASE=http://localhost:11434/v1